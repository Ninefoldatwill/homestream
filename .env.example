# === Agent Tokens ===
# Define your own agents — each agent needs a token and optional name
AGENT_1_TOKEN=your_agent_1_token_here
AGENT_2_TOKEN=your_agent_2_token_here
AGENT_3_TOKEN=your_agent_3_token_here
AGENT_4_TOKEN=your_agent_4_token_here
AGENT_5_TOKEN=your_agent_5_token_here

# Agent names (optional, defaults to Agent-1, Agent-2, ...)
# AGENT_1_NAME=Alice
# AGENT_2_NAME=Bob
# AGENT_3_NAME=Charlie

# === Elastic mode ===
# solo (lightweight, 1 agent) | team (collaboration, 3+ agents) | ecosystem (full, 5+ agents)
OPENBRIDGE_MODE=team
OPENBRIDGE_FEATURES=

# === Model Router (L1 local — zero config) ===
LLAMA_API_BASE=http://localhost:1342/v1
LLAMA_API_KEY=jan-local
LLAMA_MODEL_NAME=qwen_model.gguf

# === External APIs (progressive: fill one key to activate a tier) ===
# L2: GLM free tier -> https://open.bigmodel.cn
GLM_API_KEY=your_glm_key_here
# L3: DeepSeek paid tier -> https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_key_here

# === Dual redundancy ===
MODEL_ROUTER_DUAL_REDUNDANCY=true
MODEL_ROUTER_PRIMARY_TIERS=L1,L2
MODEL_ROUTER_BACKUP_TIER=L3
MODEL_ROUTER_TIMEOUT_PRIMARY=10
MODEL_ROUTER_TIMEOUT_BACKUP=15

# === Service ===
DEBUG=false
HOST=0.0.0.0
PORT=3458
DATABASE_URL=sqlite:///./events_v7.db

# === v5.2.0 VoiceBridge (自托管 LiveKit, 零注册) ===
# 自托管 LiveKit Server 连接 (默认 localhost, 零注册)
# 生成密钥: docker run --rm livekit/livekit-server generate-keys
VOICE_LIVEKIT_URL=ws://localhost:7880
VOICE_LIVEKIT_API_KEY=devkey
VOICE_LIVEKIT_API_SECRET=devsecret

# LLM 路由策略 (SPEED_FIRST 适合语音低延迟场景)
VOICE_ROUTER_STRATEGY=SPEED_FIRST

# VAD 参数 (Silero VAD, 本地)
VOICE_VAD_THRESHOLD=0.5
VOICE_VAD_MIN_SPEECH=0.2
VOICE_VAD_MIN_SILENCE=0.12

# STT 配置 (SenseVoice, Apache 2.0, 本地)
# 模式: local (SenseVoice) | api (外部API) | auto (优先local降级api)
VOICE_STT_MODE=auto
VOICE_STT_MODEL=iic/SenseVoiceSmall
VOICE_STT_LANGUAGE=zh
VOICE_STT_SAMPLE_RATE=16000
VOICE_STT_MAX_BUFFER=10.0
# API 降级 (可选, 不配则纯本地)
# VOICE_STT_API_KEY=your_openai_key
# VOICE_STT_API_BASE=https://api.openai.com/v1

# TTS 配置 (CosyVoice2, Apache 2.0, 本地)
# 模式: local (CosyVoice2) | api (外部API) | auto
VOICE_TTS_MODE=auto
VOICE_TTS_MODEL_PATH=pretrained_models/CosyVoice2-0.5B
VOICE_TTS_VOICE=longxiaochun
VOICE_TTS_SAMPLE_RATE=24000
VOICE_TTS_SPEED=1.0
# API 降级 (可选)
# VOICE_TTS_API_KEY=your_openai_key
# VOICE_TTS_API_BASE=https://api.openai.com/v1

# Agent 行为
VOICE_AGENT_NAME=homestream-voice
VOICE_ALLOW_INTERRUPTIONS=true
